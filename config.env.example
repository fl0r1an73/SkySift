MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=change-me
MQTT_TOPIC_PREFIX=adsb
MQTT_CLIENT_ID=skysift

ADSB_JSON_PATH=/run/readsb/aircraft.json
ADSB_STATS_PATH=/run/readsb/stats.json
ADSB_DB_PATH=/usr/local/share/tar1090/html
WATCHLIST_PATH=/opt/skysift/watchlist.json
PUBLIC_INTERESTING_PATH=/opt/skysift/public/interesting.json

POLL_INTERVAL_SEC=1.0
STALE_TIMEOUT_SEC=15.0
LOG_LEVEL=INFO

INTERESTING_REQUIRE_POSITION=true
INTERESTING_MAX_SEEN_SEC=15
INTERESTING_MAX_SEEN_POS_SEC=15
INTERESTING_ALTITUDE_MIN=
INTERESTING_ALTITUDE_MAX=
RECEIVER_LAT=
RECEIVER_LON=
INTERESTING_RADIUS_KM=
INTERESTING_CALLSIGN_PREFIXES=
INTERESTING_CATEGORIES=
